# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.tgz

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets — never commit)
.env*
!.env.example

# MCP config may contain API keys
.cursor/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- Local / agent-only (not for GitHub) ---

# Agent session memory
memory.md

# Design references & Stitch exports (large binaries)
context/designs/

# One-off design generation scripts
scripts/

# Stitch prompt drafts (design tooling only)
context/stitch-prompts.md

# Cursor agent skills & lockfile
.agents/
skills-lock.json
